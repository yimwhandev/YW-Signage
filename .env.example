# Google Sheets API (for Admin write access)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Sheets Published CSV URL (for TV display - no auth needed)
NEXT_PUBLIC_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv&gid=0

# Admin password (simple protection)
ADMIN_PASSWORD=your_secure_password_here

# App URL (for display page QR)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
