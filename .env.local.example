# Google Sheets API (สำหรับ Admin - อ่าน/เขียน)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----"
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Admin Password (ป้องกันหน้า Admin)
ADMIN_PASSWORD=your_admin_password_here

# Next.js Public (สำหรับ Player - อ่าน CSV)
# Sheet ต้อง Publish เป็น CSV ก่อน (File > Share > Publish to web > CSV)
NEXT_PUBLIC_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv&gid=0

# Refresh interval สำหรับ Player (milliseconds) - default 30 วินาที
NEXT_PUBLIC_REFRESH_INTERVAL=30000
